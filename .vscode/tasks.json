{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve dashboard locally",
      "type": "shell",
      "command": "python3 -m http.server 8090",
      "detail": "Open http://localhost:8090 to test the app (required for the service worker).",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "local-web-server",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP on"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
